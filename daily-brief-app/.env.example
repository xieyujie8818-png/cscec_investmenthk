# === 報社會員（僅存本機 .env，勿提交 Git；勿寫進代碼）===
HKEJ_EMAIL=
HKEJ_PASSWORD=
MINGPAO_USERNAME=
MINGPAO_PASSWORD=
HKET_USERNAME=
HKET_PASSWORD=

# === 服務 ===
# 127.0.0.1 = 僅本機；0.0.0.0 = 同網絡同事可訪問 http://你的IP:8765
HOST=127.0.0.1
PORT=8765

# Daily auto-run at 10:00 Hong Kong time (Mon-Fri)
ENABLE_SCHEDULER=true
SCHEDULE_HOUR=10
SCHEDULE_MINUTE=0
